model Saga {
  id          String @id @default(uuid()) @db.Uuid
  sagaType    String @map("saga_type") // BOOKING_SAGA
  referenceId String @map("reference_id") // bookingId

  status      SagaStatus
  currentStep String?    @map("current_step")

  retryCount   Int     @default(0) @map("retry_count")
  errorMessage String? @map("error_message")

  steps SagaStep[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([referenceId])
  @@index([status])
  @@index([referenceId, sagaType])
  @@map("saga")
}

enum SagaStatus {
  started // Saga created, not yet executing first step
  in_progress // At least one step running
  compensating // Running rollback steps
  completed // Successfully finished all steps
  failed // Failed and cannot recover (manual intervention needed)
  compensated // All completed steps were successfully rolled back
  timeout // Expired due to time constraint

  @@map("enum_saga_status")
}

// started : Saga record created but execution hasn’t begun.
// in_progress: Normal execution phase.
// compensating: A step failed, and rollback is running.
// completed : Happy path finished.
// failed :Hard failure. No more automatic retries.
// compensated : Rollback completed successfully.
// timeout: Expired before finishing (e.g., booking expired)
