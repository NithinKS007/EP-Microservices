model Payment {
  id        String @id @default(uuid()) @db.Uuid
  bookingId String @map("fk_booking_id") @db.Uuid
  userId    String @map("fk_user_id") @db.Uuid

  amount   Decimal @db.Decimal(10, 2)
  currency String

  status      PaymentStatus
  provider    String
  providerRef String?       @unique @map("provider_ref")
  providerPaymentId String? @unique @map("provider_payment_id")

  paymentEvent PaymentEvent[]
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@index([bookingId])
  @@map("payments")
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
  REFUNDED

  @@map("enum_payment_status")
}
